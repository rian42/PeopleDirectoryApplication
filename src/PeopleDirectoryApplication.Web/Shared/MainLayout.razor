@inherits LayoutComponentBase

<div class="page-shell">
    <header class="border-bottom bg-light">
        <div class="container d-flex justify-content-between align-items-center py-2">
            <a href="/" class="text-decoration-none fw-bold fs-5">People Directory</a>
            <AuthorizeView>
                <Authorized>
                    <div class="d-flex gap-3">
                        <a href="/" class="text-decoration-none">Search</a>
                        <a href="/admin/people" class="text-decoration-none">Admin</a>
                        <a href="/Account/Logout" class="text-decoration-none">Logout</a>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <div class="d-flex gap-3">
                        <a href="/" class="text-decoration-none">Search</a>
                        <a href="/Account/Login" class="text-decoration-none">Admin Login</a>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </header>

    <main class="container py-4">
        @Body
    </main>
</div>
